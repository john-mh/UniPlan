generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model EventStatistics {
  id               Int      @id @default(autoincrement())
  eventId          String   @unique @map("event_id") @db.VarChar(24)
  totalRegistered  Int      @default(0) @map("total_registered")
  totalCancelled   Int      @default(0) @map("total_cancelled")
  totalAttended    Int      @default(0) @map("total_attended")
  demographics    Json?    @map("demographics")
  lastUpdated      DateTime @default(now()) @map("last_updated")

  @@map("uniplan_statistics")
}
